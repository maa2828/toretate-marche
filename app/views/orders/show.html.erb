<div class="container mx-auto px-4 py-8 max-w-4xl">
  <div class="bg-green-50 border-l-4 border-green-600 p-4 mb-6">
    <div class="flex items-center">
      <svg class="w-6 h-6 text-green-600 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
      </svg>
      <p class="text-green-800 font-semibold">ご注文ありがとうございます!</p>
    </div>
  </div>

  <h1 class="text-3xl font-bold mb-6">注文詳細</h1>

  <div class="bg-white rounded-lg shadow-lg overflow-hidden mb-6">
    <div class="p-6">
      <div class="mb-6">
        <p class="text-gray-600">注文番号: <span class="font-semibold">#<%= @order.id %></span></p>
        <p class="text-gray-600">注文日時: <span class="font-semibold"><%= @order.created_at.strftime('%Y年%m月%d日 %H:%M') %></span></p>
        <p class="text-gray-600">ステータス:
          <span class="px-3 py-1 rounded <%= @order.pending? ? 'bg-yellow-100 text-yellow-800' : @order.confirmed? ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
            <%= @order.pending? ? '注文受付中' : @order.confirmed? ? '確定済み' : 'キャンセル' %>
          </span>
        </p>
      </div>

      <h2 class="text-xl font-semibold mb-4">注文内容</h2>

      <div class="space-y-4 mb-6">
        <% @order.order_items.each do |item| %>
          <div class="flex items-center gap-3 py-3 border-b">
            <% if item.product&.image&.attached? %>
              <%= image_tag item.product.image, class: "w-16 h-16 object-cover rounded flex-shrink-0" %>
            <% end %>
            <div class="flex-1 min-w-0">
              <p class="font-medium"><%= item.title_snapshot %></p>
              <p class="text-sm text-gray-500">出品者: <%= item.product&.seller&.name || '削除済み' %></p>
              <p class="text-sm text-gray-500 mt-1">¥<%= number_with_delimiter(item.price_snapshot) %> × <%= item.quantity %>個</p>
            </div>
            <div class="text-right flex-shrink-0">
              <p class="font-semibold">¥<%= number_with_delimiter(item.price_snapshot * item.quantity) %></p>
            </div>
          </div>
        <% end %>
      </div>

      <div class="border-t pt-4">
        <div class="flex justify-between items-center text-2xl font-bold">
          <span>合計金額:</span>
          <span class="text-green-600">¥<%= number_with_delimiter(@order.total_amount) %></span>
        </div>
      </div>
    </div>
  </div>

  <div class="flex space-x-4">
    <%= link_to "← 注文履歴に戻る", orders_path, class: "text-blue-600 hover:underline" %>
    <%= link_to "商品一覧に戻る", products_path, class: "bg-green-600 text-white px-6 py-3 rounded-lg hover:bg-green-700" %>
  </div>
</div>
