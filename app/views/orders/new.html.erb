<div class="container mx-auto px-4 py-8 max-w-4xl">
  <h1 class="text-3xl font-bold mb-6">注文確認</h1>

  <div class="bg-white rounded-lg shadow-lg overflow-hidden mb-6">
    <div class="p-6">
      <h2 class="text-xl font-semibold mb-4">注文内容</h2>
      
      <table class="w-full mb-6">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left text-sm font-medium text-gray-500">商品</th>
            <th class="px-4 py-3 text-left text-sm font-medium text-gray-500">価格</th>
            <th class="px-4 py-3 text-left text-sm font-medium text-gray-500">数量</th>
            <th class="px-4 py-3 text-left text-sm font-medium text-gray-500">小計</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-200">
          <% @cart_items.each do |item| %>
            <tr>
              <td class="px-4 py-4">
                <div class="flex items-center">
                  <% if item[:product].image.attached? %>
                    <%= image_tag item[:product].image, class: "w-12 h-12 object-cover rounded mr-3" %>
                  <% end %>
                  <div>
                    <p class="font-medium"><%= item[:product].title %></p>
                    <p class="text-sm text-gray-500">出品者: <%= item[:product].seller.name %></p>
                  </div>
                </div>
              </td>
              <td class="px-4 py-4">¥<%= number_with_delimiter(item[:product].price) %></td>
              <td class="px-4 py-4"><%= item[:quantity] %>個</td>
              <td class="px-4 py-4 font-semibold">¥<%= number_with_delimiter(item[:subtotal]) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <div class="border-t pt-4">
        <div class="flex justify-between items-center text-xl font-bold">
          <span>合計金額:</span>
          <span class="text-green-600">¥<%= number_with_delimiter(@total) %></span>
        </div>
      </div>
    </div>
  </div>

  <div class="flex justify-between items-center">
    <%= link_to "← カートに戻る", cart_path, class: "text-blue-600 hover:underline" %>
    <%= button_to "注文を確定する", orders_path, method: :post, class: "bg-green-600 text-white px-8 py-3 rounded-lg hover:bg-green-700 font-semibold", data: { confirm: "この内容で注文を確定しますか?" } %>
  </div>
</div>
